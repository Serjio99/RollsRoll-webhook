# Server
PORT=3010
NODE_ENV=development

# Webhook protection: this value must be sent in X-Webhook-Secret
WEBHOOK_SECRET=test-secret-123

# Delivery targets: suvvy, telegram, max.
DELIVERY_TARGETS=suvvy

# Suvvy custom channel incoming message API.
MOCK_SUVVY_ENABLED=false
SUVVY_DELIVERY_MODE=widget
SUVVY_TELEGRAM_WEBHOOK_URL=https://api.suvvy.ai/api/webhook/telegram/update/...
SUVVY_API_URL=
SUVVY_API_TOKEN=
SUVVY_CHAT_ID_FIELD=suvvy_external_id
SUVVY_WIDGET_ORIGIN_URL=https://webhook.prom-logic.ru
SUVVY_WIDGET_SESSION_PREFIX=
SUVVY_REQUEST_TIMEOUT_MS=10000

# Production Suvvy bot API goes here instead of the demo URL above:
# MOCK_SUVVY_ENABLED=false
# SUVVY_API_URL=https://your-suvvy-bot.example/api/frontpad/order-status
# SUVVY_API_TOKEN=real-suvvy-token

# Optional direct Telegram mirror for internal testing/admin notifications.
# Add telegram to DELIVERY_TARGETS only when these values are real.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional direct MAX delivery. In the preferred architecture MAX stays behind Suvvy.
# Add max to DELIVERY_TARGETS only when the MAX bot API endpoint and token are real.
MAX_ENABLED=false
MAX_API_URL=
MAX_BOT_TOKEN=

# Suvvy.ai website chat widget.
WEBSITE_CHAT_ENABLED=true
WEBSITE_CHAT_PROVIDER=suvvy
SUVVY_WIDGET_ID=6986f6d7e613891db708a4f469f0efc4235d3e5c9db2da88
JIVO_WIDGET_ID=
SHOW_CHAT_PLACEHOLDER=false
LOCAL_SITE_CHAT_ENABLED=true

# Optional: override status messages by status_id as JSON object
# STATUS_MESSAGES_JSON={"3":"Ваш заказ #{order_number} принят.","4":"Ваш заказ #{order_number} готовится."}


